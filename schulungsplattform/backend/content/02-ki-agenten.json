  "reference": [
    {
      "term": "KI-Agent",
      "definition": "Ein Programm, das ein LLM nutzt, um ein Ziel ueber mehrere Schritte selbststaendig zu verfolgen."
    },
    {
      "term": "Agent Loop",
      "definition": "Reason (planen), Act (handeln), Observe (Ergebnis lesen) - wiederholen bis Ziel erreicht."
    },
    {
      "term": "Modell (LLM)",
      "definition": "Das Gehirn des Agenten: plant, entscheidet und erzeugt Tool Calls."
    },
    {
      "term": "Instruktionen",
      "definition": "Der System-Prompt - legt Rolle, Ziel und Grenzen fest."
    },
    {
      "term": "Werkzeuge (Tools)",
      "definition": "Funktionen fuer den Zugriff auf die Aussenwelt."
    },
    {
      "term": "Speicher (Memory)",
      "definition": "Gespraechsverlauf und Tool-Ergebnisse im Kontext-Fenster."
    }
  ]
