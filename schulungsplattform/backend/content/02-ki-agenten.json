              "type": "step",
              "emoji": "🧠",
              "label": "Agent denkt",
              "sublabel": "Was muss ich tun?"
            },
            {
              "id": "act",
              "type": "step",
              "emoji": "⚡",
              "label": "Agent handelt",
              "sublabel": "Tool Call oder Antwort"
            },
            {
              "id": "done",
              "type": "end",
              "emoji": "✅",
              "label": "Ziel erreicht",
              "sublabel": "Ergebnis zurueck"
            }
          ],
          "loop": {
            "label": "Noch nicht fertig"
          }
        }
      ]
    },
